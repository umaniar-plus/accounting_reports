<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="partner_ledger_report.partnerLedgerReport" owl="1">
        <div t-att-class="'partner-ledger-container ' + (Object.values(state.collapsedPartners || {}).some(v => !v)? 'container-expanded': '')">
            <!-- Header with Filters -->
            <div class="row mx-2 mt-3">
                <div class="col-lg-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="row mx-2 mt-0 align-items-end filter-row">
                                <!-- Title -->
                                <div class="col-md-2">
                                    <span class="section-title">
                                        <a href="" onclick="location.reload();" class="section-title">Partner Ledger</a>
                                   </span>
                                </div>

                                <!-- Filters/Search/Buttons -->
                                <div class="col d-flex justify-content-end align-items-end flex-wrap filters-container">
                                    <div class="input-group me-2">
                                        <input type="text" class="form-control" placeholder="Search here..." t-ref="search-input" t-on-keydown="onSearchKeydown"/>
                                        <button class="btn btn-outline-primary" t-on-click="searchJournal">Search</button>
                                    </div>

                                    <div class="d-flex align-items-center gap-2 me-2 flex-wrap filters-row">
                                        <!-- Main Dropdown for Date Type -->
                                        <div class="dropdown flex-shrink-0">
                                            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                <t t-esc="state.dateType || 'Filter'"/>
                                            </button>
                                            <ul class="dropdown-menu">
                                                <li><a class="dropdown-item" t-on-click="selectDateType.bind(this, 'Month')">Month</a></li>
                                                <li><a class="dropdown-item" t-on-click="selectDateType.bind(this, 'Quarter')">Quarter</a></li>
                                                <li><a class="dropdown-item" t-on-click="selectDateType.bind(this, 'Year')">Year</a></li>
                                                <li><a class="dropdown-item" t-on-click="selectDateType.bind(this, 'Custom')">Custom Dates</a></li>
                                            </ul>
                                        </div>

                                        
                                        <!-- Conditional Inputs as Dropdowns -->
                                        <t t-if="state.dateType === 'Month'">
                                            <div class="dropdown flex-grow-1">
                                                <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                                                    <t t-esc="state.selectedMonth || 'Select Month'"/>
                                                </button>
                                                <ul class="dropdown-menu">
                                                    <t t-foreach="['January','February','March','April','May','June','July','August','September','October','November','December']" t-as="m" t-key="m">
                                                        <li><a class="dropdown-item" t-on-click="selectMonth.bind(this, m)"><t t-esc="m"/></a></li>
                                                    </t>
                                                </ul>
                                            </div>
                                            <div class="dropdown flex-grow-1">
                                                <button class="btn btn-outline-secondary dropdown-toggle w-100"
                                                        type="button"
                                                        data-bs-toggle="dropdown">
                                                    <t t-esc="state.selectedYear"/>
                                                </button>

                                                <ul class="dropdown-menu">
                                                    <t t-foreach="state.availableYears"
                                                       t-as="year"
                                                       t-key="year">
                                                        <li>
                                                            <a class="dropdown-item"
                                                               t-on-click="onYearSelect.bind(this, year)">
                                                                <t t-esc="year"/>
                                                            </a>
                                                        </li>
                                                    </t>
                                                </ul>
                                            </div>
                                        </t>
                                        <t t-if="state.dateType === 'Quarter'">
                                            <div class="dropdown flex-grow-1">
                                                <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                                                    <t t-esc="state.selectedQuarter || 'Select Quarter'"/>
                                                </button>
                                                <ul class="dropdown-menu">
                                                    <li><a class="dropdown-item" t-on-click="selectQuarter.bind(this, 'Q1')">Q1 (Jan-Mar)</a></li>
                                                    <li><a class="dropdown-item" t-on-click="selectQuarter.bind(this, 'Q2')">Q2 (Apr-Jun)</a></li>
                                                    <li><a class="dropdown-item" t-on-click="selectQuarter.bind(this, 'Q3')">Q3 (Jul-Sep)</a></li>
                                                    <li><a class="dropdown-item" t-on-click="selectQuarter.bind(this, 'Q4')">Q4 (Oct-Dec)</a></li>
                                                </ul>
                                            </div>
                                            <div class="dropdown flex-grow-1">
                                                <button class="btn btn-outline-secondary dropdown-toggle w-100"
                                                        type="button"
                                                        data-bs-toggle="dropdown">
                                                    <t t-esc="state.selectedYear"/>
                                                </button>

                                                <ul class="dropdown-menu">
                                                    <t t-foreach="state.availableYears"
                                                       t-as="year"
                                                       t-key="year">
                                                        <li>
                                                            <a class="dropdown-item"
                                                               t-on-click="onYearSelect.bind(this, year)">
                                                                <t t-esc="year"/>
                                                            </a>
                                                        </li>
                                                    </t>
                                                </ul>
                                            </div>
                                        </t>
                                        <t t-if="state.dateType === 'Year'">
                                            <div class="dropdown flex-grow-1">
                                                <button class="btn btn-outline-secondary dropdown-toggle w-100"
                                                        type="button"
                                                        data-bs-toggle="dropdown">
                                                    <t t-esc="state.selectedYear"/>
                                                </button>
                                            
                                                <ul class="dropdown-menu">
                                                    <t t-foreach="state.availableYears"
                                                       t-as="year"
                                                       t-key="year">
                                                        <li>
                                                            <a class="dropdown-item"
                                                               t-on-click="selectFinancialYear.bind(this, year)">
                                                                <t t-esc="year"/>
                                                            </a>
                                                        </li>
                                                    </t>
                                                </ul>
                                            </div>
                                        </t>
                                        <t t-if="state.dateType === 'Custom'">
                                            <input id="date-from" type="date" class="form-control flex-grow-1 w-auto me-2" t-ref="date-from" t-on-change="onCustomDateFromChange"/>
                                            <input id="date-to" type="date" class="form-control flex-grow-1 w-auto" t-ref="date-to"/>
                                        </t>
                                    </div>

                                    <!-- Account Type Filter -->

                                    <div class="dropdown me-2">
                                        
                                        <button class="btn btn-outline-secondary dropdown-toggle"
                                                type="button"
                                                data-bs-toggle="dropdown">
                                    
                                            <i class="fa fa-user me-1"/>
                                    
                                            Account:
                                            <t t-esc="
                                                state.selectedAccountType === 'receivable'
                                                    ? 'Receivable'
                                                    : state.selectedAccountType === 'payable'
                                                        ? 'Payable'
                                                        : 'All'
                                            "/>
                                    
                                        </button>
                                    
                                        <ul class="dropdown-menu">
                                    
                                            <li>
                                                <a class="dropdown-item"
                                                   t-on-click="() => this.selectAccountType('all')">
                                                    All
                                                </a>
                                            </li>
                                    
                                            <li>
                                                <a class="dropdown-item"
                                                   t-on-click="() => this.selectAccountType('receivable')">
                                                    Receivable
                                                </a>
                                            </li>
                                    
                                            <li>
                                                <a class="dropdown-item"
                                                   t-on-click="() => this.selectAccountType('payable')">
                                                    Payable
                                                </a>
                                            </li>
                                    
                                        </ul>
                                    
                                    </div>

                                    <div class="d-flex">
                                        <t t-if="state.dateType === 'Custom'">
                                            <button class="btn btn-primary me-2" t-on-click="applyFilters">Apply</button>
                                        </t>
                                        <!-- Export Dropdown -->
                                        <div class="dropdown">
                                            <button class="btn btn-success dropdown-toggle" t-att-disabled="!state.ledgerData.length" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                Export
                                            </button>
                                            <ul class="dropdown-menu">
                                                <li><a class="dropdown-item" t-on-click="exportToPDF">PDF</a></li>
                                                <li><a class="dropdown-item" t-on-click="exportToXLSX">XLSX</a></li>
                                            </ul>
                                        </div>
                                    </div>

                                    <t t-if="state.isDebug">
                                        <button class="btn btn-outline-danger ms-2" title="Debug Mode Active" t-on-click="openDebugConfig">
                                            <i class="fa fa-bug"/>
                                        </button>
                                    </t>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Active Filter Display -->
            <div class="row m-2">
                <div class="col">
                    <div class="alert alert-info py-2 mb-0">
                        <span class="partner-title" t-esc="getActiveDateRangeLabel()"/>
                    </div>
                </div>
            </div>

            <!-- partner Ledger Body -->
            <div class="row m-2">
                <div class="col">
                    <div class="card">
                        <div class="ledger-table-wrapper">
                            <div class="card-body p-0">

                                <table class="table table-sm mb-0 ledger-shared-table">

                                    <thead class="enterprise-header">

                                        <tr>

                                            <th t-if="state.config.show_journal" data-col="journal">
                                                Journal
                                            </th>

                                            <th t-if="state.config.show_date"
                                                data-col="date"
                                                style="cursor:pointer;"
                                                t-on-click.stop="sortByDate">

                                                Date

                                                <span t-esc="state.sortDirection === 'asc' ? '↑' : '↓'"/>

                                            </th>

                                            <th t-if="state.config.show_due_date"
                                                data-col="due_date">

                                                Due Date

                                            </th>

                                            <th t-if="state.config.show_partner"
                                                data-col="amount"
                                                class="text-end">

                                                Transaction Amount Currency

                                            </th>

                                            <th t-if="state.config.show_currency"
                                                data-col="currency">

                                                Currency

                                            </th>

                                            <th t-if="state.config.show_debit"
                                                data-col="debit"
                                                class="text-end">

                                                Debit

                                            </th>

                                            <th t-if="state.config.show_credit"
                                                data-col="credit"
                                                class="text-end">

                                                Credit

                                            </th>

                                            <th t-if="state.config.show_balance"
                                                data-col="balance"
                                                class="text-end">

                                                Balance

                                            </th>

                                        </tr>

                                    </thead>


                                </table>

                                <div t-foreach="state.groupedData" t-as="partner" t-key="partner.partner_name" class="partner-group bg-light">
                                    <!-- Account Header -->
                                    <table class="table table-sm mb-0 ledger-shared-table partner-header-table">

                                    <tbody>

                                        <tr t-att-class="
                                            'partner-header border-bottom ' +
                                            (!state.collapsedPartners[partner.partner_name]
                                            ? 'partner-expanded'
                                            : '')
                                        "

                                        t-on-click="togglePartner.bind(this, partner.partner_name)">

                                            <!-- Journal -->

                                            <td data-col="journal">

                                                <div class="d-flex align-items-center">

                                                    <i t-att-class="
                                                        state.collapsedPartners[partner.partner_name]
                                                        ? 'fa fa-chevron-right me-2'
                                                        : 'fa fa-chevron-down me-2'
                                                    "/>

                                                    <span class="partner-title"
                                                        t-esc="partner.partner_name"/>

                                                </div>

                                            </td>

                                            <!-- Date -->

                                            <td t-if="state.config.show_date"
                                                data-col="date">
                                            </td>

                                            <!-- Due Date -->

                                            <td t-if="state.config.show_due_date"
                                                data-col="due_date">
                                            </td>

                                            <!-- Transaction Amount -->

                                            <td t-if="state.config.show_partner"
                                                data-col="amount">
                                            </td>

                                            <!-- Currency -->

                                            <td t-if="state.config.show_currency"
                                                data-col="currency">
                                            </td>

                                            <!-- Debit -->

                                            <td t-if="state.config.show_debit"
                                                data-col="debit"
                                                class="text-end">

                                                <t t-if="state.collapsedPartners[partner.partner_name]">

                                                    <t t-esc="
                                                        formatCurrency(
                                                            partner.debit,
                                                            partner.lines[0]?.currency_symbol || '₹'
                                                        )
                                                    "/>

                                                </t>

                                            </td>

                                            <!-- Credit -->

                                            <td t-if="state.config.show_credit"
                                                data-col="credit"
                                                class="text-end">

                                                <t t-if="state.collapsedPartners[partner.partner_name]">

                                                    <t t-esc="
                                                        formatCurrency(
                                                            partner.credit,
                                                            partner.lines[0]?.currency_symbol || '₹'
                                                        )
                                                    "/>

                                                </t>

                                            </td>

                                            <!-- Balance -->

                                            <td t-if="state.config.show_balance"
                                                data-col="balance"
                                                class="text-end">

                                                <t t-if="state.collapsedPartners[partner.partner_name]">

                                                    <t t-esc="
                                                        formatCurrency(
                                                            partner.balance,
                                                            partner.lines[0]?.currency_symbol || '₹'
                                                        )
                                                    "/>

                                                </t>

                                            </td>

                                        </tr>

                                    </tbody>

                                    </table>

                                    <!-- Account Details Table -->
                                    <t t-if="!state.collapsedPartners[partner.partner_name]">
                                        <table class="table table-sm mb-0 ledger-shared-table account-detail-table">
                                            <tbody>
                                                <tr t-foreach="partner.lines.slice(0,state.visibleLinesCount[partner.partner_name] || 100)" t-as="line" t-key="line.id"
                                                    t-on-click="() => this.viewJournalEntry(line.move_id[0])"
                                                    t-att-class="line.move_name === 'Initial Balance' ? 'table-secondary fw-bold' : ''">

                                                    <t>
                                                        <td t-if="state.config.show_journal" data-col="journal" data-label="Journal" style="text-align:left;">
                                                            <div class="d-flex flex-column">
                                                                <span class="text-muted" t-esc="line.move_name"/><t t-if="line.name and line.name != line.move_name">
                                                                <span t-esc="line.name"/></t>
                                                            </div>
                                                        </td>

                                                        <td t-if="state.config.show_date" data-col="date" data-label="Date"><span t-esc="formatDate(line.date)"/></td>
                                                        <td t-if="state.config.show_due_date" data-col="due_date" data-label="Due Date"><span t-esc="formatDate(line.date_maturity)"/></td>

                                                        <td t-if="state.config.show_partner" data-col="amount" data-label = "Transaction Amount Currency" style="text-align : right;">
                                                            <t t-if="line.currency_id and line.amount_currency">
                                                            <span t-esc="formatCurrency(line.amount_currency,line.currency_symbol)"/>
                                                            </t>
                                                        </td>

                                                        <td t-if="state.config.show_currency" data-col="currency" data-label="Currency">
                                                            <span class="badge bg-secondary" t-esc="line.currency_id ? line.currency_id[1] : ''"/>
                                                        </td>
                                                        <td t-if="state.config.show_debit" data-col="debit" data-label="Debit" class="text-end">
                                                            <span t-att-class="getAmountClass(line.debit)"  style="white-space: nowrap;">
                                                                <t t-esc="line.debit > 0 ? formatCurrency(line.debit, '₹', line.currency_id ? line.currency_id[1] : null) : '₹' + ' 0'"/>
                                                            </span>
                                                        </td>
                                                        <td t-if="state.config.show_credit" data-col="credit" data-label="Credit" class="text-end">
                                                            <span t-att-class="getAmountClass(line.credit)"  style="white-space: nowrap;">
                                                                <t t-esc="line.credit > 0 ? formatCurrency(line.credit, '₹', line.currency_id ? line.currency_id[1] : null) : '₹' + ' 0'"/>
                                                            </span>
                                                        </td>
                                                        <td t-if="state.config.show_balance" data-col="balance" data-label="Balance" class="text-end">
                                                            <span t-att-class="getAmountClass(line.balance)"  style="white-space: nowrap;">
                                                                <t t-esc="formatCurrency(line.balance, '₹', line.currency_id ? line.currency_id[1] : null)"/>
                                                            </span>
                                                        </td>
                                                    </t>
                                                </tr>

                                                <t t-if="
                                                    partner.lines.length >
                                                    (state.visibleLinesCount[partner.partner_name] || 100)
                                                ">
                                                    <tr>
                                                        <td colspan="99" class="text-center">
                                                            <button
                                                                class="btn btn-link"
                                                                t-on-click.stop="
                                                                    () => this.loadMore(partner.partner_name)
                                                                ">
                                                                Load More
                                                            </button>
                                                        </td>
                                                    </tr>
                                                </t>

                                                <!-- Total Row -->
                                                <tr class="table-total">

                                                    <td data-label="Total"
                                                        t-att-colspan="
                                                            (state.config.show_journal ? 1 : 0) +
                                                            (state.config.show_date ? 1 : 0) +
                                                            (state.config.show_due_date ? 1 : 0) +
                                                            (state.config.show_partner ? 1 : 0) +
                                                            (state.config.show_currency ? 1 : 0)"
                                                        style="font-weight:bold;">
                                                        Total <t t-esc="partner.partner_name"/>
                                                    </td>
                                                    <td t-if="state.config.show_debit" data-label="Debit" class="text-end" style = "font-weight: bold;">
                                                        <t t-esc="formatCurrency(partner.debit, partner.lines[0]?.currency_symbol, partner.lines[0]?.currency_id ? partner.lines[0].currency_id[1] : null)"/>
                                                    </td>
                                                    <td t-if="state.config.show_credit" data-label="Credit" class="text-end" style = "font-weight: bold;">
                                                        <t t-esc="formatCurrency(partner.credit, partner.lines[0]?.currency_symbol, partner.lines[0]?.currency_id ? partner.lines[0].currency_id[1] : null)"/>
                                                    </td>
                                                    <td t-if="state.config.show_balance" data-label="Balance" class="text-end" style = "font-weight: bold;">
                                                        <t t-esc="formatCurrency(partner.balance, partner.lines[0]?.currency_symbol, partner.lines[0]?.currency_id ? partner.lines[0].currency_id[1] : null)"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </t>
                                </div>
                                </div>

                                    <!-- grand total -->
                                <div class="grand-total bg-light border-top">

                                    <table class="table table-sm mb-0 ledger-shared-table">

                                        <tbody>

                                            <tr class="table-total fw-bold">

                                                <td data-col="journal">

                                                    Total

                                                </td>

                                                <td t-if="state.config.show_date"
                                                    data-col="date">
                                                </td>

                                                <td t-if="state.config.show_due_date"
                                                    data-col="due_date">
                                                </td>

                                                <td t-if="state.config.show_partner"
                                                    data-col="amount">
                                                </td>

                                                <td t-if="state.config.show_currency"
                                                    data-col="currency">
                                                </td>

                                                <td t-if="state.config.show_debit"
                                                    data-col="debit"
                                                    class="text-end">

                                                    <t t-esc="
                                                        formatCurrency(
                                                            state.totals.debit,
                                                            '₹',
                                                            state.ledgerData[0]?.currency_id
                                                            ? state.ledgerData[0].currency_id[1]
                                                            : null
                                                        )
                                                    "/>

                                                </td>

                                                <td t-if="state.config.show_credit"
                                                    data-col="credit"
                                                    class="text-end">

                                                    <t t-esc="
                                                        formatCurrency(
                                                            state.totals.credit,
                                                            '₹',
                                                            state.ledgerData[0]?.currency_id
                                                            ? state.ledgerData[0].currency_id[1]
                                                            : null
                                                        )
                                                    "/>

                                                </td>

                                                <td t-if="state.config.show_balance"
                                                    data-col="balance"
                                                    class="text-end">

                                                    <t t-esc="
                                                        formatCurrency(
                                                            state.totals.balance,
                                                            '₹',
                                                            state.ledgerData[0]?.currency_id
                                                            ? state.ledgerData[0].currency_id[1]
                                                            : null
                                                        )
                                                    "/>

                                                </td>

                                            </tr>

                                        </tbody>

                                    </table>

                                </div>
                            </div>
                        </div>
                </div>
            </div>
        </div>
    </t>

</templates>
