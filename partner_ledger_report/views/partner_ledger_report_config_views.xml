<odoo>
    <record id="view_partner_ledger_config_form" model="ir.ui.view">
        <field name="name">partner.ledger.report.config.form</field>
        <field name="model">partner.ledger.report.config</field>
        <field name="arch" type="xml">
            <form string="Partner Ledger Configuration">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group string="Column Visibility">
                        <field name="show_journal"/>
                        <field name="show_date"/>
                        <field name="show_due_date"/>
                        <field name="show_communication"/>
                        <field name="show_partner"/>
                        <field name="show_currency"/>
                        <field name="show_debit"/>
                        <field name="show_credit"/>
                        <field name="show_balance"/>
                    </group>
                    <field name="company_id" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
