<odoo>
    <record id="view_aged_payable_config_form" model="ir.ui.view">
        <field name="name">aged.payable.report.config.form</field>
        <field name="model">aged.payable.report.config</field>
        <field name="arch" type="xml">
            <form string="aged payable Configuration">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group string="Column Visibility">
                        <field name="show_invoice"/>
                        <field name="show_invoice_date"/>
                        <field name="show_at_date"/>
                        <field name="show_bucket_1"/>
                        <field name="show_bucket_2"/>
                        <field name="show_bucket_3"/>
                        <field name="show_bucket_4"/>
                        <field name="show_older"/>
                        <field name="show_total"/>
                    </group>
                    <group string="Aging settings">
                        <field name="aging_basis"/>
                    </group>
                    <field name="company_id" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
